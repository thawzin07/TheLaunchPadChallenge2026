# App
NEXT_PUBLIC_APP_NAME=ApplyOS
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth is handled by Supabase Auth using the public Supabase URL/key below.
# Keep false in production after custom SMTP or normal Supabase email delivery is configured.
AUTH_ALLOW_UNVERIFIED_SIGNUP_FALLBACK=false

# Database
# Supabase Postgres
# Runtime connection. Use Supabase Transaction pooler, usually port 6543.
DATABASE_URL="postgresql://postgres.your-project-ref:password@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Migration connection. Use Supabase Session pooler, usually port 5432.
DIRECT_URL="postgresql://postgres.your-project-ref:password@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Storage placeholders
SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_STORAGE_BUCKET=resumes

# AI routing
AI_PRIMARY_PROVIDER=openai
AI_ENABLE_PROVIDER_COMPARISON=false
AI_MOCK_MODE=true
AI_TIMEOUT_MS=60000
AI_MAX_RETRIES=2

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Agnes AI
AGNES_API_KEY=
AGNES_API_BASE_URL=
AGNES_MODEL=

# GMI Cloud
GMI_API_KEY=
GMI_API_BASE_URL=
GMI_MODEL=

# Jobs - Adzuna
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=sg

# Jobs - Optional curated ATS sources
GREENHOUSE_BOARD_TOKENS=
LEVER_COMPANY_HANDLES=
INDEED_API_KEY=
